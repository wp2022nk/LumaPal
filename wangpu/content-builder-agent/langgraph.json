{
  "dependencies": ["."],
  "graphs": {
    "content_writer": "./content_builder/langgraph_app.py:agent"
  },
  "python_version": "3.11",
  "pip_installer": "pip",
  "env": {
    "FF_V2_EVENT_STREAMING": "true",
    "CONTENT_BUILDER_REQUIRE_EXECUTE_CONFIRMATION": "false",
    "PYTHONUTF8": "1"
  },
  "http": {
    "app": "./content_builder/web_api.py:app",
    "cors": {
      "allow_origins": [
        "http://localhost:5173",
        "http://127.0.0.1:5173",
        "http://localhost:5174",
        "http://127.0.0.1:5174",
        "http://localhost:5175",
        "http://127.0.0.1:5175",
        "http://localhost:5176",
        "http://127.0.0.1:5176",
        "http://localhost:5177",
        "http://127.0.0.1:5177",
        "http://localhost:5178",
        "http://127.0.0.1:5178",
        "http://localhost:5179",
        "http://127.0.0.1:5179",
        "http://localhost:5180",
        "http://127.0.0.1:5180"
      ],
      "allow_methods": ["*"],
      "allow_headers": ["*"],
      "allow_credentials": true
    }
  }
}
